{
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/version-bump-check.sh"
          }
        ]
      }
    ]
  }
}
